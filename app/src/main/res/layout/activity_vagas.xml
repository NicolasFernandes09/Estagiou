<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootTelaVagas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/estagiou_panel_bg"
    tools:context=".activity.VagasActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerVagas"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/vagasCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_full_panel"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="460dp">

            <LinearLayout
                android:id="@+id/headerVagas"
                android:layout_width="0dp"
                android:layout_height="168dp"
                android:background="@drawable/bg_header_orange_full"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/txtTituloVagas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Vagas"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloVagas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Oportunidades para começar sua carreira"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:id="@+id/viewCirculoLaranjaVagas"
                android:layout_width="136dp"
                android:layout_height="136dp"
                android:background="@drawable/bg_circle_orange"
                android:translationX="-18dp"
                android:translationY="-43dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/viewCirculoAmareloVagas"
                android:layout_width="196dp"
                android:layout_height="196dp"
                android:background="@drawable/bg_circle_gold"
                android:translationX="68dp"
                android:translationY="68dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/vagasContent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="24dp"
                android:paddingEnd="28dp"
                app:layout_constraintBottom_toTopOf="@id/bottomVagasFixo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerVagas">

                <EditText
                    android:id="@+id/edtBuscaVaga"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:autofillHints="none"
                    android:background="@drawable/bg_search_box"
                    android:drawableStart="@drawable/ic_search_20"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    android:hint="Buscar vaga, empresa ou cidade"
                    android:inputType="text"
                    android:paddingStart="24dp"
                    android:paddingEnd="18dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="16sp" />

                <HorizontalScrollView
                    android:id="@+id/scrollFiltrosVagas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/filtrosVagas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnFiltroTodas"
                            android:layout_width="93dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_filter_selected"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="Todas"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnFiltroEstagio"
                            android:layout_width="107dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_filter_outline"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="Estágio"
                            android:textAllCaps="false"
                            android:textColor="@color/estagiou_orange_corporate"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnFiltroJovemAprendiz"
                            android:layout_width="150dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_filter_outline"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="Jovem Aprendiz"
                            android:textAllCaps="false"
                            android:textColor="@color/estagiou_orange_corporate"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnFiltroFreelancer"
                            android:layout_width="118dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_filter_outline"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="Freelancer"
                            android:textAllCaps="false"
                            android:textColor="@color/estagiou_orange_corporate"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnFiltroClt"
                            android:layout_width="76dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="2dp"
                            android:background="@drawable/bg_filter_outline"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="CLT"
                            android:textAllCaps="false"
                            android:textColor="@color/estagiou_orange_corporate"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>

                <ProgressBar
                    android:id="@+id/progressVagas"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="28dp"
                    android:indeterminateTint="@color/estagiou_orange_corporate" />

                <LinearLayout
                    android:id="@+id/boxErroVagas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_apply_box"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtErroVagas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Não foi possível carregar as vagas."
                        android:textColor="@color/estagiou_text_primary"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnTentarNovamenteVagas"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_primary_button"
                        android:minHeight="0dp"
                        android:text="Tentar novamente"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtSemResultadosVagas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Nenhuma vaga encontrada."
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerVagas"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="18dp"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_vaga" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottomVagasFixo"
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:background="@drawable/bg_full_panel"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:id="@+id/navInicioFixoVagas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgInicioFixoVagas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Início"
                        android:src="@drawable/ic_home_22" />

                    <TextView
                        android:id="@+id/txtInicioFixoVagas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Início"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navFavoritosFixoVagas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgFavoritosFixoVagas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Favoritos"
                        android:src="@drawable/ic_heart_filled_22" />

                    <TextView
                        android:id="@+id/txtFavoritosFixoVagas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Favoritos"
                        android:textColor="@color/estagiou_hint"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navPerfilFixoVagas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgPerfilFixoVagas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Perfil"
                        android:src="@drawable/ic_profile_22" />

                    <TextView
                        android:id="@+id/txtPerfilFixoVagas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Perfil"
                        android:textColor="@color/estagiou_hint"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
