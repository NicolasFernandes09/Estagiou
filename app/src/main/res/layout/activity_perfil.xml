<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootTelaPerfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/estagiou_panel_bg"
    tools:context=".classes.PerfilActivity">

    <ScrollView
        android:id="@+id/telaPerfil"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="112dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/containerPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:minHeight="760dp"
            android:paddingStart="0dp"
            android:paddingTop="0dp"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardPerfil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_full_panel"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_max="460dp">

                <LinearLayout
                    android:id="@+id/headerPerfil"
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:background="@drawable/bg_header_orange_full"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="30dp"
                    android:paddingEnd="30dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/txtTituloPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Perfil"
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtSubtituloPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Sua conta no Estagiou"
                        android:textColor="@color/white"
                        android:textSize="16sp" />
                </LinearLayout>

                <View
                    android:id="@+id/viewCirculoLaranjaPerfil"
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:background="@drawable/bg_circle_orange"
                    android:translationX="-18dp"
                    android:translationY="-43dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/viewCirculoAmareloPerfil"
                    android:layout_width="196dp"
                    android:layout_height="196dp"
                    android:background="@drawable/bg_circle_gold"
                    android:translationX="68dp"
                    android:translationY="68dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/perfilContent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingTop="28dp"
                    android:paddingEnd="28dp"
                    android:paddingBottom="132dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/headerPerfil">

                    <LinearLayout
                        android:id="@+id/cardDadosPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_job_card"
                        android:orientation="vertical"
                        android:paddingStart="22dp"
                        android:paddingTop="20dp"
                        android:paddingEnd="22dp"
                        android:paddingBottom="20dp">

                        <LinearLayout
                            android:id="@+id/linhaTopoPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/imgFotoPerfil"
                                android:layout_width="82dp"
                                android:layout_height="82dp"
                                android:background="@drawable/bg_company_badge"
                                android:contentDescription="Foto do usuário"
                                android:padding="20dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_profile_22" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtNomePerfil"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/estagiou_text_primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    tools:text="Rafael Klein" />

                                <TextView
                                    android:id="@+id/txtUsuarioPerfil"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textColor="@color/estagiou_text_secondary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="@rafael" />

                                <TextView
                                    android:id="@+id/txtEmailPerfil"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textColor="@color/estagiou_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="rafael@email.com" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtRotuloDescricaoProfissionalPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Descrição profissional"
                            android:textColor="@color/estagiou_text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDescricaoPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/estagiou_text_primary"
                            android:textSize="16sp"
                            tools:text="Estudante em busca de estágio." />

                        <TextView
                            android:id="@+id/txtRotuloDescricaoPessoalPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Descrição pessoal"
                            android:textColor="@color/estagiou_text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDescricaoPessoalPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/estagiou_text_primary"
                            android:textSize="16sp"
                            tools:text="Gosto de tecnologia e trabalho em equipe." />

                        <TextView
                            android:id="@+id/txtStatusPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Conta ativa para consultar vagas e favoritos."
                            android:textColor="@color/estagiou_text_secondary"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnEditarPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/bg_filter_outline"
                        android:backgroundTint="@color/white"
                        android:text="Editar perfil"
                        android:textAllCaps="false"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnSairPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_primary_button"
                        android:backgroundTint="@color/estagiou_orange_dynamic"
                        android:text="Sair da conta"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomPerfilFixo"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_full_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="36dp"
        android:paddingEnd="36dp">

        <LinearLayout
            android:id="@+id/navInicioFixoPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgInicioFixoPerfil"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Início"
                android:src="@drawable/ic_home_22" />

            <TextView
                android:id="@+id/txtInicioFixoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Início"
                android:textColor="@color/estagiou_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFavoritosFixoPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgFavoritosFixoPerfil"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Favoritos"
                android:src="@drawable/ic_heart_filled_22" />

            <TextView
                android:id="@+id/txtFavoritosFixoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Favoritos"
                android:textColor="@color/estagiou_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfilFixoPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgPerfilFixoPerfil"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Perfil"
                android:src="@drawable/ic_profile_22" />

            <TextView
                android:id="@+id/txtPerfilFixoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Perfil"
                android:textColor="@color/estagiou_orange_corporate"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
