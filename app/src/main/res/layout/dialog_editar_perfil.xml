<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

    <LinearLayout
        android:id="@+id/dialogEditarPerfilContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="8dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/imgFotoEditarPerfil"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_company_badge"
            android:contentDescription="Foto do usuário"
            android:padding="20dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_22" />

        <Button
            android:id="@+id/btnSelecionarFotoEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_filter_outline"
            android:backgroundTint="@color/white"
            android:minWidth="0dp"
            android:text="Trocar foto"
            android:textAllCaps="false"
            android:textColor="@color/estagiou_orange_corporate"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtNomeEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:hint="Nome completo"
            android:inputType="textPersonName"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:textColor="@color/estagiou_text_primary"
            android:textColorHint="@color/estagiou_hint"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/edtEmailEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:textColor="@color/estagiou_text_primary"
            android:textColorHint="@color/estagiou_hint"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/edtDescricaoProfissionalEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:hint="Descrição profissional"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="450"
            android:minHeight="88dp"
            android:minLines="3"
            android:overScrollMode="never"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:scrollbars="none"
            android:textColor="@color/estagiou_text_primary"
            android:textColorHint="@color/estagiou_hint"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtRestanteDescricaoProfissionalEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="450 caracteres restantes"
            android:textColor="@color/estagiou_text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtDescricaoPessoalEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:hint="Descrição pessoal"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="450"
            android:minHeight="88dp"
            android:minLines="3"
            android:overScrollMode="never"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:scrollbars="none"
            android:textColor="@color/estagiou_text_primary"
            android:textColorHint="@color/estagiou_hint"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtRestanteDescricaoPessoalEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="450 caracteres restantes"
            android:textColor="@color/estagiou_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
