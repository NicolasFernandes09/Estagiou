<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/estagiou_screen_bg"
    android:fillViewport="true"
    tools:context=".classes.RegistrarActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:minHeight="640dp"
        android:paddingStart="14dp"
        android:paddingTop="4dp"
        android:paddingEnd="14dp"
        android:paddingBottom="22dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/registerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_panel"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0"
            app:layout_constraintWidth_max="420dp">

            <LinearLayout
                android:id="@+id/headerRegister"
                android:layout_width="0dp"
                android:layout_height="134dp"
                android:background="@drawable/bg_header_orange"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/txtRegistro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Criar conta"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Cadastro simples para alunos"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="118dp"
                android:layout_height="118dp"
                android:background="@drawable/bg_circle_orange"
                android:translationX="18dp"
                android:translationY="-36dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="156dp"
                android:layout_height="156dp"
                android:background="@drawable/bg_circle_gold"
                android:translationX="56dp"
                android:translationY="48dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/registerContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerRegister">

                <TextView
                    android:id="@+id/txtDados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Dados de acesso"
                    android:textColor="@color/estagiou_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Nome completo"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtNome"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:autofillHints="name"
                    android:background="@drawable/bg_input"
                    android:hint="Seu nome"
                    android:inputType="textPersonName"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Usuário"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtUsuarioCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:autofillHints="username"
                    android:background="@drawable/bg_input"
                    android:hint="crie seu usuário"
                    android:inputType="text"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="E-mail"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtGmail"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/bg_input"
                    android:hint="Digite seu e-mail"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtAjudaEmailCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Use um e-mail real, ele será usado no login."
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Foto do perfil"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/linhaFotoCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgFotoCadastro"
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_company_badge"
                        android:contentDescription="Foto do usuário"
                        android:padding="18dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile_22" />

                    <Button
                        android:id="@+id/btnSelecionarFotoCadastro"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_filter_outline"
                        android:backgroundTint="@color/white"
                        android:minWidth="0dp"
                        android:text="Escolher foto"
                        android:textAllCaps="false"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Descrição profissional"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDescricaoCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="Ex: estudante em busca de estágio"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="450"
                    android:minHeight="88dp"
                    android:minLines="3"
                    android:overScrollMode="never"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:scrollbars="none"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtRestanteDescricaoCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="end"
                    android:text="450 caracteres restantes"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Descrição pessoal"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDescricaoPessoalCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="Ex: gosto de tecnologia e trabalho em equipe"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="450"
                    android:minHeight="88dp"
                    android:minLines="3"
                    android:overScrollMode="never"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:scrollbars="none"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtRestanteDescricaoPessoalCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="end"
                    android:text="450 caracteres restantes"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Senha"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtPass1"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:autofillHints="newPassword"
                    android:background="@drawable/bg_input"
                    android:drawableStart="@drawable/ic_lock_20"
                    android:drawablePadding="8dp"
                    android:hint="mínimo 6 caracteres"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Confirmar senha"
                    android:textColor="@color/estagiou_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtPass2"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:autofillHints="newPassword"
                    android:background="@drawable/bg_input"
                    android:drawableStart="@drawable/ic_lock_20"
                    android:drawablePadding="8dp"
                    android:hint="repita a senha"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:textColor="@color/estagiou_text_primary"
                    android:textColorHint="@color/estagiou_hint"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="38dp"
                    android:background="@drawable/bg_primary_button"
                    android:backgroundTint="@color/estagiou_orange_dynamic"
                    android:text="Cadastrar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtConta2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text=""
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnEntrar2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:color/transparent"
                    android:backgroundTint="@color/estagiou_transparent"
                    android:minWidth="0dp"
                    android:stateListAnimator="@null"
                    android:text="Já tenho conta"
                    android:textAllCaps="false"
                    android:textColor="@color/estagiou_orange_corporate"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
</LinearLayout>
