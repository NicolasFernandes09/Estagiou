<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootTelaFavoritos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/estagiou_panel_bg"
    tools:context=".classes.MainActivity">

    <ScrollView
        android:id="@+id/telaFavoritos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="112dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerFavoritos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:minHeight="760dp"
        android:paddingStart="0dp"
        android:paddingTop="0dp"
        android:paddingEnd="0dp"
        android:paddingBottom="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardFavoritos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_full_panel"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="460dp">

            <LinearLayout
                android:id="@+id/headerFavoritos"
                android:layout_width="0dp"
                android:layout_height="170dp"
                android:background="@drawable/bg_header_orange_full"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/txtTituloFavoritos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Favoritos"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloFavoritos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Vagas salvas para enviar currículo depois"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:id="@+id/viewCirculoLaranjaFavoritos"
                android:layout_width="136dp"
                android:layout_height="136dp"
                android:background="@drawable/bg_circle_orange"
                android:translationX="-18dp"
                android:translationY="-43dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/viewCirculoAmareloFavoritos"
                android:layout_width="196dp"
                android:layout_height="196dp"
                android:background="@drawable/bg_circle_gold"
                android:translationX="68dp"
                android:translationY="68dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/favoritosContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="24dp"
                android:paddingEnd="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerFavoritos">

                <LinearLayout
                    android:id="@+id/boxMensagemFavoritos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_apply_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:id="@+id/txtMensagemFavorito"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❤ Vagas adicionadas aos favoritos"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardFavoritoVaga1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:background="@drawable/bg_job_card"
                    android:minHeight="172dp"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:id="@+id/txtSiglaFavorito1"
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:background="@drawable/bg_company_badge"
                        android:gravity="center"
                        android:text="TS"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/containerDadosFavorito1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtEmpresaFavorito1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="TechSul Sistemas"
                            android:textColor="@color/estagiou_text_secondary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtTituloFavorito1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Estágio em Suporte de TI"
                            android:textColor="@color/estagiou_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtCidadeFavorito1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Canoas/RS"
                            android:textColor="@color/estagiou_text_secondary"
                            android:textSize="15sp" />

                        <LinearLayout
                            android:id="@+id/linhaAcoesFavorito1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="start"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtTipoFavorito1"
                                android:layout_width="116dp"
                                android:layout_height="31dp"
                                android:background="@drawable/bg_type_pill"
                                android:gravity="center"
                                android:text="Estágio"
                                android:textColor="@color/estagiou_orange_corporate"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnDetalhesFavorito1"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_marginTop="8dp"
                                android:background="@android:color/transparent"
                                android:backgroundTint="@color/estagiou_transparent"
                                android:gravity="start|center_vertical"
                                android:includeFontPadding="true"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:singleLine="true"
                                android:text="Ver detalhes ›"
                                android:textAllCaps="false"
                                android:textColor="@color/estagiou_orange_corporate"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/checkFavoritoSalvo1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@android:color/transparent"
                        android:button="@drawable/selector_favorite_heart"
                        android:checked="true"
                        android:contentDescription="Favorito salvo"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSemFavoritos"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="52dp"
                    android:background="@drawable/bg_job_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:id="@+id/txtNenhumaOutraVaga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Nenhuma outra vaga salva"
                        android:textColor="@color/estagiou_text_primary"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtAjudaFavoritos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="Toque no coração das vagas para salvar."
                        android:textColor="@color/estagiou_text_secondary"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottomFavoritos"
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/favoritosContent">

                <LinearLayout
                    android:id="@+id/navInicioFavoritos"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgInicioFavoritos"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Início"
                        android:src="@drawable/ic_home_22" />

                    <TextView
                        android:id="@+id/txtInicioFavoritos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Início"
                        android:textColor="@color/estagiou_orange_corporate"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navFavoritosAtivo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgFavoritosAtivo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Favoritos"
                        android:src="@drawable/ic_heart_filled_22" />

                    <TextView
                        android:id="@+id/txtFavoritosAtivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Favoritos"
                        android:textColor="@color/estagiou_hint"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navPerfilFavoritos"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgPerfilFavoritos"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Perfil"
                        android:src="@drawable/ic_profile_22" />

                    <TextView
                        android:id="@+id/txtPerfilFavoritos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Perfil"
                        android:textColor="@color/estagiou_hint"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomFavoritosFixo"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_full_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="36dp"
        android:paddingEnd="36dp">

        <LinearLayout
            android:id="@+id/navInicioFixoFavoritos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgInicioFixoFavoritos"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Início"
                android:src="@drawable/ic_home_22" />

            <TextView
                android:id="@+id/txtInicioFixoFavoritos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Início"
                android:textColor="@color/estagiou_orange_corporate"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFavoritosFixoAtivo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgFavoritosFixoAtivo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Favoritos"
                android:src="@drawable/ic_heart_filled_22" />

            <TextView
                android:id="@+id/txtFavoritosFixoAtivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Favoritos"
                android:textColor="@color/estagiou_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfilFixoFavoritos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgPerfilFixoFavoritos"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Perfil"
                android:src="@drawable/ic_profile_22" />

            <TextView
                android:id="@+id/txtPerfilFixoFavoritos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Perfil"
                android:textColor="@color/estagiou_hint"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
</LinearLayout>
